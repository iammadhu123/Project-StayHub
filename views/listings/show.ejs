<%- layout("/layouts/boilerplate") %>

<script> 
    let coordinates = <%- JSON.stringify(listing.geometry?.coordinates || [77.2090, 28.6139]) %>; 
</script>


<div class="container show-wrapper mt-4">

    <!-- MAIN LISTING CARD -->
    <div class="row justify-content-center">
        <div class="col-12 col-md-11 col-lg-9">

            <div class="card show-main-card">
                <img src="<%= listing.images.url %>" class="show-img">

                <div class="card-body">
                    <h2 class="show-title"><%= listing.title %></h2>

                    <p class="hosted-text">
                        Hosted by <i><b>@<%= listing.Owner ? listing.Owner.username : "Unknown" %></b></i>
                    </p>

                    <p><%= listing.description %></p>

                    <p class="price-text">&#8377;<%= listing.price.toLocaleString("en-IN") %> /night</p>

                    <p class="location-text"><%= listing.location %>, <%= listing.country %></p>
                </div>
            </div>

            <% if(currUser && listing.Owner && listing.Owner._id && listing.Owner._id.equals(currUser._id)) { %>
                <div class="btns mt-3 mb-4">
                    <a href="/listings/<%= listing._id %>/edit" class="btn edit-btn">Edit</a>

                    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                        <button class="btn btn-dark" type="submit">Delete</button>
                    </form>
                </div>
            <% } %>

        </div>
    </div>

    <!-- REVIEW FORM -->
    <div class="row justify-content-center mt-3">
        <div class="col-12 col-md-11 col-lg-9">

            <% if(currUser) { %>
                <div class="review-panel">
                    <h4>Leave a Review</h4>

                    <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">

                        <fieldset class="starability-growRotate mb-3">
                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                            
                            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                            <label for="first-rate1" title="Terrible">1 star</label>

                            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                            <label for="first-rate2" title="Not good">2 stars</label>

                            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                            <label for="first-rate3" title="Average">3 stars</label>

                            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                            <label for="first-rate4" title="Very good">4 stars</label>

                            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                            <label for="first-rate5" title="Amazing">5 stars</label>
                        </fieldset>

                        <div class="mb-3">
                            <textarea name="review[comment]" rows="4" class="form-control" placeholder="Write your review..." required></textarea>
                        </div>

                        <button class="btn btn-outline-dark">Submit Review</button>
                    </form>
                </div>
            <% } %>

            <% if(listing.reviews.length > 0) { %>
                <h5 class="mt-4 mb-3">Guest Reviews</h5>

                <div class="row g-3">
                    <% for(let review of listing.reviews) { %>
                        <div class="col-12 col-md-6">
                            <div class="card review-card">
                                <div class="card-body">
                                    <h6><i><b>@<%= review.author.username %></b></i></h6>
                                    <p class="starability-result" data-rating="<%= review.rating %>"></p>
                                    <p><%= review.comment %></p>

                                    <% if(currUser && review.author._id.equals(currUser._id)) { %>
                                        <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                                            <button class="btn btn-sm btn-dark">Delete</button>
                                        </form>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            <% } %>

        </div>
    </div>

    <!-- MAP -->
    <div class="row justify-content-center mt-5 mb-4">
        <div class="col-12 col-md-11 col-lg-9">
            <h3>Where you'll be</h3>
            <div id="map"></div>
        </div>
    </div>

</div>

<script src="/js/map.js"></script>